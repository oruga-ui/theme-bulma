{
  "name": "@oruga-ui/theme-bulma",
  "version": "0.9.0",
  "description": "Bulma theme for Oruga",
  "license": "MIT",
  "type": "module",
  "main": "dist/theme.cjs",
  "module": "dist/theme.js",
  "unpkg": "dist/theme.cjs",
  "types": "dist/types/theme.d.ts",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "exports": {
    ".": {
      "import": "./dist/theme.js",
      "types": "./dist/types/theme.d.ts"
    },
    "./style.css": "./dist/theme.css",
    "./style.scss": "./dist/scss/theme.scss",
    "./scss/*.scss": "./dist/scss/*.scss",
    "./dist/scss/*.scss": "./dist/scss/*.scss"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oruga-ui/theme-bulma.git"
  },
  "bugs": {
    "url": "https://github.com/oruga-ui/theme-bulma/issues"
  },
  "scripts": {
    "dev": "vite --force",
    "serve": "vite preview",
    "build": "vite build",
    "lint": "run-s lint:eslint lint:prettier lint:stylelint",
    "lint:eslint": "eslint . --fix",
    "lint:prettier": "prettier --write .",
    "lint:stylelint": "stylelint **/*.{css,scss} --fix --ignore-path .gitignore",
    "test:ts": "vue-tsc --build --noEmit",
    "test:lint": "run-s test:eslint test:prettier test:stylelint",
    "test:eslint": "eslint .",
    "test:prettier": "prettier --check .",
    "test:stylelint": "stylelint **/*.{css,scss} --ignore-path .gitignore",
    "update": "ncu -u"
  },
  "peerDependencies": {
    "@oruga-ui/oruga-next": "^0.13.0"
  },
  "dependencies": {
    "bulma": "1.0.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@oruga-ui/examples": "^0.13.6",
    "@oruga-ui/oruga-next": "^0.13.6",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "core-js": "^3.49.0",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "npm-check-updates": "^22.2.9",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "sass": "1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "typescript": "6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.1.1",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "vue-tsc": "3.3.6"
  }
}
